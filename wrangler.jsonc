{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "nathmonari-landing",
  "main": "worker/index.js",
  "compatibility_date": "2026-06-25",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  }
}
