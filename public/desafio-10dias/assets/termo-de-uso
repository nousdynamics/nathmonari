<script>
// === Função para capturar UTMs da URL ===
function getUrlParams() {
  const params = {};
  const queryString = window.location.search.substring(1);
  const regex = /([^&=]+)=([^&]*)/g;
  let m;
  while (m = regex.exec(queryString)) {
    params[decodeURIComponent(m[1])] = decodeURIComponent(m[2]);
  }
  return params;
}

document.addEventListener("DOMContentLoaded", function () {
  const params = getUrlParams();
  const utmKeys = ["utm_source", "utm_medium", "utm_campaign", "utm_term", "utm_content"];

  // Salva UTMs no localStorage
  utmKeys.forEach(function (key) {
    if (params[key]) {
      localStorage.setItem(key, params[key]);
    }
  });

  // Monta string de UTMs para acrescentar ao checkout
  function buildUtmString() {
    let query = [];
    utmKeys.forEach(function (key) {
      const value = localStorage.getItem(key);
      if (value) query.push(key + "=" + encodeURIComponent(value));
    });
    return query.length ? "?" + query.join("&") : "";
  }

  // Seleciona todos os botões/links que levam ao checkout
  const checkoutLinks = document.querySelectorAll('a[href*="greenn.co"], a[href*="greenn.club"]');

  checkoutLinks.forEach(function (link) {
    link.addEventListener("click", function (e) {
      e.preventDefault(); // previne clique imediato
      const baseUrl = link.getAttribute("href").split("?")[0]; // limpa parâmetros anteriores
      const finalUrl = baseUrl + buildUtmString();
      window.location.href = finalUrl; // redireciona com as UTMs
    });
  });
});
</script>

